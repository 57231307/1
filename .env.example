# ============================================
# Bingxi ERP 环境变量示例文件
# 说明：复制为 .env 并填写实际值
# 路径：/etc/bingxi/.env  (生产)
#      或 ./backend/.env  (开发)
# ============================================

# === 必填 - 数据库主机地址 ===
# 远程 PostgreSQL 主机 IP 或域名
DATABASE__HOST=127.0.0.1

# === 必填 - 数据库端口 ===
# PostgreSQL 默认 5432
DATABASE__PORT=5432

# === 必填 - 数据库用户名 ===
DATABASE__USERNAME=postgres

# === 必填 - 数据库密码 ===
# 强烈建议使用强密码
DATABASE__PASSWORD=请改成你的密码

# === 必填 - 数据库名称 ===
DATABASE__NAME=bingxi_erp

# === 必填 - JWT 认证密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -hex 32
# 警告（Wave B-2 B2-2）：从 v2026.617.0002 起，多副本部署必须使用相同的稳定密钥，
# 不再允许在生产环境随机生成。环境变量优先于 config.yaml。
# v18 批次 48 修复：占位符改为 value-placeholder-change-me（命中 validate_secret 黑名单），
# 防止示例配置被原样复制到生产环境
AUTH__JWT_SECRET=value-placeholder-change-me

# === 必填 - Cookie 加密密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -hex 32
# 警告（Wave B-2 B2-1）：从 v2026.617.0002 起，COOKIE_SECRET 必须独立配置，
# 禁止降级复用 AUTH__JWT_SECRET（同时暴露签名伪造和 Cookie 加密两个攻击面）。
# 缺失时后端会直接 panic 退出。请同时配置：
#   环境变量: COOKIE_SECRET
#   或 config.yaml: auth.cookie_secret
# v18 批次 48 修复：占位符改为 value-placeholder-change-me（命中 validate_secret 黑名单）
AUTH__COOKIE_SECRET=value-placeholder-change-me

# === 可选 - 上一代 JWT 密钥（密钥轮换用）===
# 在密钥轮换时使用，新旧密钥共存一段时间避免会话立即失效
# PREVIOUS_JWT_SECRET=旧的32字节密钥

# === 必填 - 审计日志密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -hex 32
# v18 批次 48 修复：占位符改为 value-placeholder-change-me（命中 validate_secret 黑名单）
AUDIT__SECRET_KEY=value-placeholder-change-me

# === 可选 - 运行环境 ===
# 取值：development / staging / production
APP__ENV=development

# === 可选 - HTTP 服务监听 ===
SERVER__HOST=0.0.0.0
SERVER__PORT=8080

# === 可选 - gRPC 服务监听 ===
GRPC__HOST=0.0.0.0
GRPC__PORT=50051

# === 可选 - 数据库连接池大小 ===
DATABASE__MAX_CONNECTIONS=20

# === 可选 - CORS 允许来源 ===
# 多个 origin 用英文逗号分隔
CORS__ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === v3 复审 P2-11 ===
# 注意：完整环境变量清单请参考 backend/.env.example（权威源）
# 本文件保留 config crate `__` 分隔符风格的配置项
