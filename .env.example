# ============================================
# Bingxi ERP 环境变量示例文件
# 说明：复制为 .env 并填写实际值
# 路径：/etc/bingxi/.env  (生产)
#      或 ./backend/.env  (开发)
# ============================================

# === 必填 - 数据库主机地址 ===
# 远程 PostgreSQL 主机 IP 或域名
DATABASE__HOST=127.0.0.1

# === 必填 - 数据库端口 ===
# PostgreSQL 默认 5432
DATABASE__PORT=5432

# === 必填 - 数据库用户名 ===
DATABASE__USERNAME=postgres

# === 必填 - 数据库密码 ===
# 强烈建议使用强密码，留空时通过环境变量 DATABASE_PASSWORD 注入
# 批次 398 修复：移除中文占位符密码（不进入 validate_secret 校验链路，易被原样复制到生产环境）
DATABASE__PASSWORD=

# === 必填 - 数据库名称 ===
DATABASE__NAME=bingxi_erp

# === 必填 - JWT 认证密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -base64 32
# 警告（Wave B-2 B2-2）：从 v2026.617.0002 起，多副本部署必须使用相同的稳定密钥，
# 不再允许在生产环境随机生成。环境变量优先于 config.yaml。
# v18 批次 48 修复：占位符改为 value-placeholder-change-me（命中 validate_secret 黑名单），
# 防止示例配置被原样复制到生产环境
# 注意：变量名必须为 JWT_SECRET（单下划线），后端 settings.rs:334 读取此变量
JWT_SECRET=value-placeholder-change-me

# === 必填 - Cookie 加密密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -base64 32
# 警告（Wave B-2 B2-1）：从 v2026.617.0002 起，COOKIE_SECRET 必须独立配置，
# 禁止降级复用 JWT_SECRET（同时暴露签名伪造和 Cookie 加密两个攻击面）。
# 缺失时后端会直接 panic 退出。请同时配置：
#   环境变量: COOKIE_SECRET
#   或 config.yaml: auth.cookie_secret
# v18 批次 48 修复：占位符改为 value-placeholder-change-me（命中 validate_secret 黑名单）
# 注意：变量名必须为 COOKIE_SECRET（单下划线），后端 settings.rs:338 读取此变量
COOKIE_SECRET=value-placeholder-change-me

# === 可选 - 上一代 JWT 密钥（密钥轮换用）===
# 在密钥轮换时使用，新旧密钥共存一段时间避免会话立即失效
# PREVIOUS_JWT_SECRET=旧的32字节密钥

# === 必填 - 审计日志密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -base64 32
# v18 批次 48 修复：占位符改为 value-placeholder-change-me（命中 validate_secret 黑名单）
# 注意：变量名必须为 AUDIT_SECRET_KEY（单下划线），后端 settings.rs:355 读取此变量
# 批次 273 修复：原 AUDIT__SECRET_KEY（双下划线）与后端读取不一致，导致校验未触发或变量缺失
AUDIT_SECRET_KEY=value-placeholder-change-me

# === 必填 - Webhook HMAC 密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -base64 32
# M-2 修复：独立 Webhook HMAC 密钥，与 JWT_SECRET 分离。
# 安全原因：JWT_SECRET 一旦泄露会导致第三方 webhook 回调被任意伪造。
# 后端 main.rs:411-419 强制要求显式配置，缺失时直接 exit(1)。
# 禁止与 JWT_SECRET 相同（app_state.rs:154 校验互不相同）。
# 批次 277 修复：部署脚本和 .env.example 缺失 WEBHOOK_SECRET 导致启动失败。
# 批次 401 修复：部署脚本自动生成密钥，首次部署无需手动配置
WEBHOOK_SECRET=value-placeholder-change-me

# === 可选 - 运行环境 ===
# 取值：development / staging / production
APP__ENV=development

# === 可选 - HTTP 服务监听 ===
SERVER__HOST=0.0.0.0
SERVER__PORT=8080

# === 可选 - gRPC 服务监听 ===
# 批次 398 修复：移除 GRPC__HOST/GRPC__PORT（项目未启用 gRPC，config.yaml.example 已注释）
# 如需恢复，请在 backend/src/config/settings.rs 中新增 GrpcConfig 结构体并接入
# GRPC__HOST=0.0.0.0
# GRPC__PORT=50051

# === 可选 - 数据库连接池大小 ===
DATABASE__MAX_CONNECTIONS=20

# === 可选 - CORS 允许来源 ===
# 多个 origin 用英文逗号分隔
CORS__ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# === v3 复审 P2-11 ===
# 注意：完整环境变量清单请参考 backend/.env.example（权威源）
# 本文件保留 config crate `__` 分隔符风格的配置项
