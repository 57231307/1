# ============================================
# Bingxi ERP 环境变量示例文件
# 说明：复制为 .env 并填写实际值
# 路径：/etc/bingxi/.env  (生产)
#      或 ./backend/.env  (开发)
# ============================================

# === 必填 - 数据库主机地址 ===
# 远程 PostgreSQL 主机 IP 或域名
DATABASE__HOST=127.0.0.1

# === 必填 - 数据库端口 ===
# PostgreSQL 默认 5432
DATABASE__PORT=5432

# === 必填 - 数据库用户名 ===
DATABASE__USERNAME=postgres

# === 必填 - 数据库密码 ===
# 强烈建议使用强密码
DATABASE__PASSWORD=请改成你的密码

# === 必填 - 数据库名称 ===
DATABASE__NAME=bingxi_erp

# === 必填 - JWT 认证密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -hex 32
AUTH__JWT_SECRET=请用 openssl rand -hex 32 生成

# === 必填 - Cookie 加密密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -hex 32
AUTH__COOKIE_SECRET=请用 openssl rand -hex 32 生成

# === 必填 - 审计日志密钥 ===
# 生产环境必须至少 32 字节，建议使用：
#   openssl rand -hex 32
AUDIT__SECRET_KEY=请用 openssl rand -hex 32 生成

# === 可选 - 运行环境 ===
# 取值：development / staging / production
APP__ENV=development

# === 可选 - HTTP 服务监听 ===
SERVER__HOST=0.0.0.0
SERVER__PORT=8080

# === 可选 - gRPC 服务监听 ===
GRPC__HOST=0.0.0.0
GRPC__PORT=50051

# === 可选 - 数据库连接池大小 ===
DATABASE__MAX_CONNECTIONS=20

# === 可选 - CORS 允许来源 ===
# 多个 origin 用英文逗号分隔
CORS__ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
