{
  "info": {
    "name": "秉羲管理系统 API",
    "description": "秉羲管理系统的完整 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1/erp",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "认证",
      "item": [
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', jsonData.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "验证 Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/verify-token",
              "host": ["{{base_url}}"],
              "path": ["auth", "verify-token"]
            }
          }
        }
      ]
    },
    {
      "name": "采购合同管理",
      "item": [
        {
          "name": "获取采购合同列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/purchase-contracts?page=1&page_size=10",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "page_size",
                  "value": "10"
                },
                {
                  "key": "keyword",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "获取单个采购合同",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/purchase-contracts/1",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts", "1"]
            }
          }
        },
        {
          "name": "创建采购合同",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contract_no\": \"PC{{timestamp}}\",\n  \"contract_name\": \"测试采购合同\",\n  \"supplier_id\": 1,\n  \"total_amount\": \"10000.00\",\n  \"payment_terms\": \"30 天账期\",\n  \"delivery_date\": \"2026-04-01\",\n  \"remark\": \"测试合同\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/purchase-contracts",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts"]
            }
          }
        },
        {
          "name": "审核采购合同",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/purchase-contracts/1/approve",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts", "1", "approve"]
            }
          }
        },
        {
          "name": "执行采购合同",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"execution_type\": \"purchase_order\",\n  \"execution_amount\": \"5000.00\",\n  \"related_bill_type\": \"purchase_order\",\n  \"related_bill_id\": 1,\n  \"remark\": \"执行备注\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/purchase-contracts/1/execute",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts", "1", "execute"]
            }
          }
        },
        {
          "name": "取消采购合同",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"取消原因\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/purchase-contracts/1/cancel",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts", "1", "cancel"]
            }
          }
        },
        {
          "name": "删除采购合同",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/purchase-contracts/1",
              "host": ["{{base_url}}"],
              "path": ["purchase-contracts", "1"]
            }
          }
        }
      ]
    },
