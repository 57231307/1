# 面料管理 - 本地开发配置文件模板
#
# 安全警告：此文件为配置模板，复制并重命名为 config.yaml 后使用
# 生产环境请使用环境变量覆盖敏感配置
# 环境变量优先级高于此文件
#
# 必需的环境变量（生产环境必须设置）：
#   - DATABASE_PASSWORD (数据库密码)
#   - JWT_SECRET (JWT 密钥，至少 32 字节)
#   - COOKIE_SECRET (Cookie 密钥，至少 32 字节)
#   - AUDIT_SECRET_KEY (审计密钥，至少 32 字节)
# 生成方法: openssl rand -base64 32

server:
  host: "127.0.0.1"
  port: "8082"

database:
  connection_string: ""
  host: "localhost"
  port: 5432
  name: "bingxi"
  username: "bingxi"
  # ⚠️ 安全警告：生产环境必须通过环境变量 DATABASE_PASSWORD 设置
  password: ""  # 留空，通过环境变量设置
  max_connections: 50
  # 批次 389 P2-3：移除 AppSettings 未定义的 5 个字段（用户修改不生效，易误导运维）
  # 原字段：min_connections / acquire_timeout_ms / idle_timeout_ms / max_lifetime_ms / ssl_mode / ssl_ca
  # - min_connections: SeaORM 连接池未暴露此配置项，按 max_connections 比例自动管理
  # - acquire_timeout_ms / idle_timeout_ms / max_lifetime_ms: 需在代码层接入，当前未读取
  # - ssl_mode / ssl_ca: 批次 24 v6 P0-3 SSL 强制策略改由连接字符串参数（?sslmode=require）实现，
  #   生产环境在 DATABASE_URL 中追加 ?sslmode=require 即可生效
  # 如需恢复这些字段，请在 backend/src/config/settings.rs 的 DatabaseConfig 中新增对应字段并接入 SeaORM

auth:
  # ⚠️ 安全警告：生产环境必须通过环境变量 JWT_SECRET 设置至少 32 字节的强随机密钥
  jwt_secret: ""  # 留空，通过环境变量设置
  # ⚠️ 安全警告：生产环境必须通过环境变量 COOKIE_SECRET 设置至少 32 字节的强随机密钥
  cookie_secret: ""  # 留空，通过环境变量设置
  # M-2 修复：第三方 Webhook 回调 HMAC 密钥，必须与 JWT_SECRET 互不相同
  # ⚠️ 安全警告：生产环境必须通过环境变量 WEBHOOK_SECRET 设置至少 32 字节的强随机密钥
  webhook_secret: ""  # 留空，通过环境变量设置
  # 批次 389 P2-3：移除 AppSettings 未定义的 token_expiry_hours（用户修改不生效）
  # 原 token_expiry_hours: 24 → JWT 过期时间当前在 auth_service 中硬编码为 2 小时
  # 如需可配置化，请在 backend/src/config/settings.rs 的 AuthConfig 中新增字段并接入 auth_service
  # JWT 密钥轮换：PREVIOUS_JWT_SECRET 环境变量（可选，密钥轮换期双密钥并行验证）
  previous_jwt_secret: null
  # M-2 修复：webhook 是否复用 JWT_SECRET（仅迁移期 true，生产必须 false）
  webhook_inherit_jwt_secret: false
# 批次 389 P2-3：移除 AppSettings 未定义的 grpc 段（用户修改不生效，易误导运维）
# 原字段：grpc.host / grpc.port → 项目当前未启用 gRPC 服务，全部走 HTTP REST
# 如需恢复，请在 backend/src/config/settings.rs 中新增 GrpcConfig 结构体并接入

log:
  # ⚠️ 生产环境建议设置为 info 或 warn
  level: "info"
  dir: "./logs"

cors:
  # ⚠️ 生产环境必须配置实际域名，移除所有 localhost
  allowed_origins:
    - "http://localhost:3000"
    - "http://127.0.0.1:3000"
    - "http://localhost"
    - "http://127.0.0.1"

# 事件总线配置（Kafka 可选后端，P11-H2 引入）
# - 默认 enabled=false：进程内 tokio::sync::broadcast，CI 环境无 Kafka 也能启动
# - 生产环境设置 KAFKA_ENABLED=true 启用真实跨服务后端
kafka:
  enabled: false
  brokers: "localhost:9092"
  topic: "erp_business_events"
  consumer_group: "erp_event_consumer"
  client_id: "bingxi-erp"
  partitions: 12
  replication_factor: 1
  connect_timeout_ms: 5000
  auto_create_topic: true

# 慢查询采集配置（部署-3 修复，P13 批 1 B-慢查询审计）
# - enabled=true（默认）：启动后台任务每 5 分钟采集 pg_stat_statements，写入 slow_query_log 表
# - enabled=false：CI 容器 / 未安装 pg_stat_statements 扩展的环境可关闭
# - 失败降级：采集失败仅 warn 记录，不阻断服务启动
slow_query:
  enabled: true
  interval_secs: 300       # 采集间隔（秒）
  threshold_ms: 100.0      # 慢查询阈值（毫秒），超过此值的 SQL 才会被记录
  limit_rows: 100          # 单次采集最大行数

# 批次 398 修复：env 字段现已接入 is_production() 判定链路
# AppSettings::new() 启动时若 APP_ENV 环境变量未设置，会将此字段同步到 APP_ENV
# 优先级：APP_ENV 环境变量 > config.yaml env 字段
# 部署建议：生产环境同时在 .env 或 systemd Environment= 中显式设置 APP_ENV=production（双保险）
env: "production"
