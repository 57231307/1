# ════════════════════════════════════════════════════════════════════
# ⚠️  安全配置说明（v5 审计批次 21）
# ════════════════════════════════════════════════════════════════════
# 本文件为示例配置模板，所有敏感字段均使用 `value-placeholder-change-me` 占位。
# 该占位符会命中 `validate_secret` 的黑名单（包含 "placeholder"/"change-me"），
# 启动时直接被拒绝，防止示例配置被原样复制到生产环境。
#
# 部署要求：
#   1. 复制本文件为 .env
#   2. 将所有 value-placeholder-change-me 替换为真实强随机密钥
#   3. 密钥生成方法：openssl rand -hex 32（输出 64 字符 / 32 字节随机串）
#   4. JWT_SECRET / COOKIE_SECRET / WEBHOOK_SECRET / AUDIT_SECRET_KEY 必须互不相同
#   5. 生产环境通过环境变量或密钥管理服务注入，禁止提交到版本控制
# ════════════════════════════════════════════════════════════════════

# 数据库配置（生产环境必须设置为真实密码）
DATABASE_PASSWORD=value-placeholder-change-me

# 认证配置（使用 openssl rand -hex 32 生成，每个密钥 64 字符 / 32 字节）
# JWT_SECRET、COOKIE_SECRET、WEBHOOK_SECRET、AUDIT_SECRET_KEY 必须独立生成互不相同
# 占位符 value-placeholder-change-me 会在启动时被 validate_secret 拒绝
JWT_SECRET=value-placeholder-change-me
COOKIE_SECRET=value-placeholder-change-me
# M-2 修复：第三方 Webhook 回调 HMAC 密钥，必须与 JWT_SECRET 互不相同
WEBHOOK_SECRET=value-placeholder-change-me
# 综合审计日志签名密钥（至少32字节），生产环境必须设置，否则启动 panic
AUDIT_SECRET_KEY=value-placeholder-change-me

# 事件总线后端（P11-H2 引入 Kafka 可选）
# KAFKA_ENABLED=false（默认）：进程内 broadcast 后端，CI/开发环境友好
# KAFKA_ENABLED=true：启用 rskafka 真实后端，跨服务可用
# 生产部署：建议 KAFKA_ENABLED=true，并提供可达的 KAFKA_BROKERS
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=erp_business_events
KAFKA_CONSUMER_GROUP=erp_event_consumer
KAFKA_CLIENT_ID=bingxi-erp

# 环境变量
ENV=development

# === v3 复审 P2-11：补全缺失环境变量 ===

# === 应用环境 ===
# 注意：APP_ENV 用于 is_production() 判断（utils/config.rs），与 APP__ENV 是不同变量
APP_ENV=development
ENV=development

# === 数据库连接（DATABASE__* 的替代方案） ===
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === 初始化接口认证（敏感，生产环境必填） ===
# INIT_TOKEN=使用 openssl rand -hex 32 生成

# === 审计日志保留天数（默认 365） ===
AUDIT_RETENTION_DAYS=365

# === Redis 缓存 ===
REDIS_URL=redis://localhost:6379
# JTI 黑名单专用 Redis（不配置则复用 REDIS_URL）
# JTI_REDIS_URL=redis://localhost:6379
# 限流专用 Redis（不配置则复用 REDIS_URL）
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# === 进程内缓存配置 ===
CACHE_ENABLED=true
CACHE_CAPACITY=10000
CACHE_TTL_SECS=60

# === OpenTelemetry 可观测性 ===
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bingxi-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACE_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_SAMPLE_RATIO=1.0
OTEL_EXPORT_INTERVAL=30

# === 邮件服务（可选，未配置则邮件功能禁用） ===
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=你的 API Key
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=系统通知

# === 部署路径（CLI 工具用，可选） ===
BINGXI_INSTALL_DIR=/opt/bingxi-erp
BINGXI_LOG_DIR=/opt/bingxi-erp/logs
BINGXI_BACKUP_DIR=/opt/bingxi-erp/backups
BINGXI_SLOW_QUERY_MS=100
FRONTEND_STATIC_DIR=/workspace/frontend/static

# === 安全开关 ===
AUTH_CHECK_USER_ACTIVE=true

# === Failover 主备故障切换（可选，failover.toml 不存在时不生效） ===
# DATABASE_URL_PRIMARY=postgres://user:pass@primary-host:5432/db
# DATABASE_URL_BACKUP=postgres://user:pass@backup-host:5432/db
# DATABASE_PRIMARY_TIMEOUT_MS=3000
# DATABASE_BACKUP_TIMEOUT_MS=5000
# DATABASE_CB_THRESHOLD=5
# DATABASE_CB_DURATION_S=30
# CACHE_LRU_MAX_ENTRIES=10000
# CACHE_PRIMARY_TIMEOUT_MS=1000
# CACHE_BACKUP_TIMEOUT_MS=0
