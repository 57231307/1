# ════════════════════════════════════════════════════════════════════
# ⚠️  安全配置说明（v5 审计批次 21）
# ════════════════════════════════════════════════════════════════════
# 本文件为示例配置模板，所有敏感字段均使用 `value-placeholder-change-me` 占位。
# 该占位符会命中 `validate_secret` 的黑名单（包含 "placeholder"/"change-me"），
# 启动时直接被拒绝，防止示例配置被原样复制到生产环境。
#
# 部署要求：
#   1. 复制本文件为 .env
#   2. 将所有 value-placeholder-change-me 替换为真实强随机密钥
#   3. 密钥生成方法：openssl rand -hex 32（输出 64 字符 / 32 字节随机串）
#   4. JWT_SECRET / COOKIE_SECRET / WEBHOOK_SECRET / AUDIT_SECRET_KEY 必须互不相同
#   5. 生产环境通过环境变量或密钥管理服务注入，禁止提交到版本控制
# ════════════════════════════════════════════════════════════════════

# 数据库配置（生产环境必须设置为真实密码）
DATABASE_PASSWORD=value-placeholder-change-me

# 认证配置（使用 openssl rand -hex 32 生成，每个密钥 64 字符 / 32 字节）
# JWT_SECRET、COOKIE_SECRET、WEBHOOK_SECRET、AUDIT_SECRET_KEY 必须独立生成互不相同
# 占位符 value-placeholder-change-me 会在启动时被 validate_secret 拒绝
JWT_SECRET=value-placeholder-change-me
COOKIE_SECRET=value-placeholder-change-me
# M-2 修复：第三方 Webhook 回调 HMAC 密钥，必须与 JWT_SECRET 互不相同
WEBHOOK_SECRET=value-placeholder-change-me
# 综合审计日志签名密钥（至少32字节），生产环境必须设置，否则启动 panic
AUDIT_SECRET_KEY=value-placeholder-change-me

# 事件总线后端（P11-H2 引入 Kafka 可选）
# KAFKA_ENABLED=false（默认）：进程内 broadcast 后端，CI/开发环境友好
# KAFKA_ENABLED=true：启用 rskafka 真实后端，跨服务可用
# 生产部署：建议 KAFKA_ENABLED=true，并提供可达的 KAFKA_BROKERS
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=erp_business_events
KAFKA_CONSUMER_GROUP=erp_event_consumer
KAFKA_CLIENT_ID=bingxi-erp

# Elasticsearch 搜索引擎配置（批次 104 P0-1 引入）
# 未设置或为空：使用 mock 搜索客户端（内存 HashMap，适用于开发/测试/CI 环境）
# 已设置：使用真实 ES 客户端（reqwest 直连 ES REST API，生产环境）
# 生产部署：建议配置可达的 ES 服务地址，启用真实搜索
ELASTICSEARCH_URL=

# 环境变量
ENV=development

# === v3 复审 P2-11：补全缺失环境变量 ===

# === 应用环境 ===
# ⚠️ 关键：APP_ENV 用于 utils/config.rs::is_production() 判断（生产环境脱敏、Cookie Secure 等）
# 批次 398 修复：APP_ENV 未设置时，AppSettings::new() 会从 config.yaml 的 env 字段同步
# 优先级：APP_ENV 环境变量 > config.yaml env 字段（环境变量已设置时不覆盖）
# 部署建议：生产环境同时在 .env 或 systemd Environment= 中显式设置 APP_ENV=production（双保险）
# 批次 95 P3-14 修复：移除重复的 ENV 定义（上方第 40 行已定义 ENV=development）
APP_ENV=development

# === 数据库连接（DATABASE__* 的替代方案） ===
# 批次 389 P2-3：补充 DATABASE_URL 显式占位行（settings.rs 中 load_sensitive_from_env 会读取）
# 优先级：DATABASE_URL > database.connection_string > 自动拼接 host/port/name/username/password
# 生产环境推荐使用 DATABASE_URL（含 sslmode 参数）：postgres://user:pass@host:5432/dbname?sslmode=require
# DATABASE_URL=postgres://bingxi:password@localhost:5432/bingxi?sslmode=require

# === JWT 密钥轮换（可选，密钥轮换期使用） ===
# 批次 389 P2-3：补充 PREVIOUS_JWT_SECRET 显式占位行（settings.rs 中 load_sensitive_from_env 会读取）
# 用途：JWT 密钥轮换期间，旧 Token 仍能通过 PREVIOUS_JWT_SECRET 验证，实现无缝切换
# 轮换完成后清除该变量即可，新 Token 仅用 JWT_SECRET 签发与验证
# PREVIOUS_JWT_SECRET=value-placeholder-change-me

# === CORS 允许来源（生产环境必填） ===
# 批次 389 P2-3：补充 CORS__ALLOWED_ORIGINS 显式占位行（settings.rs 第 293 行会读取并覆盖 config.yaml）
# ⚠️ 生产环境必须配置实际域名，移除所有 localhost
# 多个域名用逗号分隔：https://erp.example.com,https://admin.example.com
# 不配置时默认仅允许 http://localhost:3000（开发环境友好，生产环境需显式覆盖）
# CORS__ALLOWED_ORIGINS=https://erp.example.com

# === 管理员密码哈希生成（CLI 工具用） ===
# 批次 389 P2-3：补充 BINGXI_ADMIN_PASSWORD 显式占位行（cli/admin.rs::read_password 会读取）
# 用途：bingxi admin hash-password 命令的密码来源（优先级：环境变量 > --password-stdin）
# 安全：仅在生成密码哈希时临时设置，生成完成后立即清除，避免明文密码长期留存环境变量
# 示例：export BINGXI_ADMIN_PASSWORD='你的密码' && bingxi admin hash-password --password-stdin
# BINGXI_ADMIN_PASSWORD=value-placeholder-change-me

# === 初始化接口认证（敏感，生产环境必填） ===
# L-43 修复（批次 370 v13 复审）：显式占位行，避免 silent default
# 生产环境请用 `openssl rand -hex 32` 生成真实值替换
INIT_TOKEN=change-me-to-random-64-hex-chars

# === 审计日志保留天数（默认 365） ===
AUDIT_RETENTION_DAYS=365

# === Redis 缓存 ===
REDIS_URL=redis://localhost:6379
# JTI 黑名单专用 Redis（不配置则复用 REDIS_URL）
# JTI_REDIS_URL=redis://localhost:6379
# 限流专用 Redis（不配置则复用 REDIS_URL）
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# === 进程内缓存配置 ===
CACHE_ENABLED=true
CACHE_CAPACITY=10000
CACHE_TTL_SECS=60

# === OpenTelemetry 可观测性 ===
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bingxi-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACE_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_SAMPLE_RATIO=1.0
OTEL_EXPORT_INTERVAL=30

# === 邮件服务（可选，未配置则邮件功能禁用） ===
# 支持的 provider：
#   - sendgrid: SendGrid API（api_key = SendGrid API Key）
#   - aliyun:   阿里云邮件推送 DirectMail（api_key = <AccessKeyId>:<AccessKeySecret>）
#   - tencent:  腾讯云邮件服务 SES（api_key = <SecretId>:<SecretKey>）
# EMAIL_PROVIDER=sendgrid
# EMAIL_API_KEY=你的 API Key（aliyun/tencent 格式为 <Id>:<Secret>）
# EMAIL_FROM=noreply@example.com
# EMAIL_FROM_NAME=系统通知

# === 部署路径（CLI 工具用，可选） ===
BINGXI_INSTALL_DIR=/opt/bingxi-erp
BINGXI_LOG_DIR=/opt/bingxi-erp/logs
BINGXI_BACKUP_DIR=/opt/bingxi-erp/backups
BINGXI_SLOW_QUERY_MS=100
FRONTEND_STATIC_DIR=/workspace/frontend/static
# L-44 修复（批次 379 v13 复审）：显式声明 BINGXI_ENV_FILE/BINGXI_SYSTEMD_DIR，避免 silent default
# .env 文件路径（备份/恢复 CLI 用，默认 /etc/bingxi/.env）
BINGXI_ENV_FILE=/etc/bingxi/.env
# systemd 服务目录（备份/恢复 CLI 用，默认 /etc/systemd/system）
BINGXI_SYSTEMD_DIR=/etc/systemd/system

# === 外部 API 配置（可选） ===
# 汇率 API 基础 URL（默认 https://api.exchangerate-api.com/v4/latest）
# EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest

# === 安全开关 ===
AUTH_CHECK_USER_ACTIVE=true
