# 数据库配置
DATABASE_PASSWORD=your_secure_password_here

# 认证配置（使用 openssl rand -hex 32 生成，每个密钥 64 字符 / 32 字节）
# JWT_SECRET、COOKIE_SECRET、WEBHOOK_SECRET 必须独立生成互不相同
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
COOKIE_SECRET=your_cookie_secret_at_least_32_chars_long
# M-2 修复：第三方 Webhook 回调 HMAC 密钥，必须与 JWT_SECRET 互不相同
WEBHOOK_SECRET=your_webhook_secret_at_least_32_chars_long

# 事件总线后端（P11-H2 引入 Kafka 可选）
# KAFKA_ENABLED=false（默认）：进程内 broadcast 后端，CI/开发环境友好
# KAFKA_ENABLED=true：启用 rskafka 真实后端，跨服务可用
# 生产部署：建议 KAFKA_ENABLED=true，并提供可达的 KAFKA_BROKERS
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=erp_business_events
KAFKA_CONSUMER_GROUP=erp_event_consumer
KAFKA_CLIENT_ID=bingxi-erp

# 环境变量
ENV=development
