# ============================================
# 秉羲 ERP 系统环境变量配置示例
# ============================================
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制系统

# ============================================
# 数据库配置 (必需)
# ============================================
DATABASE_PASSWORD=your_secure_database_password_here

# ============================================
# 认证配置 (必需)
# ============================================
# JWT 密钥 - 必须至少 32 字节
# 生成方法: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_at_least_32_bytes_here

# Cookie 密钥 - 必须至少 32 字节
COOKIE_SECRET=your_secure_cookie_secret_at_least_32_bytes_here

# 旧的 JWT 密钥 (用于密钥轮换时)
# PREVIOUS_JWT_SECRET=previous_jwt_secret_if_rotating

# ============================================
# 审计配置 (必需)
# ============================================
# 审计日志签名密钥 - 必须至少 32 字节
# 生成方法: openssl rand -base64 32
AUDIT_SECRET_KEY=your_secure_audit_secret_key_at_least_32_bytes_here

# ============================================
# CORS 配置 (可选)
# ============================================
# 允许的跨域来源，逗号分隔
# CORS__ALLOWED_ORIGINS=http://localhost:3000,https://erp.example.com

# ============================================
# 安全警告
# ============================================
# 1. 不要在配置文件中硬编码敏感信息
# 2. 生产环境必须使用强随机密钥
# 3. 定期轮换密钥
# 4. 监控密钥使用情况
