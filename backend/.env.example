# 秉羲管理系统 - 环境配置文件
# 注意：此文件包含敏感信息，请勿提交到版本控制系统

# ==================== 服务器配置 ====================
# 服务器监听地址（生产环境使用服务器 IP）
SERVER__HOST=0.0.0.0
# 服务器端口
SERVER__PORT=8080

# ==================== 数据库配置 ====================
# PostgreSQL 数据库连接字符串
# 格式：postgres://用户名：密码@主机：端口/数据库名
DATABASE__CONNECTION_STRING=postgres://user:password@192.168.1.100:5432/bingxi_erp
# 数据库主机
DATABASE__HOST=192.168.1.100
# 数据库端口
DATABASE__PORT=5432
# 数据库名称
DATABASE__NAME=bingxi_erp
# 数据库用户名
DATABASE__USERNAME=user
# 数据库密码
DATABASE__PASSWORD=password
# 数据库最大连接数
DATABASE__MAX_CONNECTIONS=10
# SSL 模式（disable, prefer, require, verify-ca, verify-full）
DATABASE__SSL_MODE=prefer
# SSL CA 证书路径（可选，用于 verify-ca 或 verify-full 模式）
DATABASE__SSL_CA=

# ==================== 认证配置 ====================
# JWT 密钥（生产环境必须使用至少 32 字节的强随机字符串，例如通过 `openssl rand -base64 32` 生成）
AUTH__JWT_SECRET=
# Token 有效期（小时）
AUTH__TOKEN_EXPIRY_HOURS=24

# ==================== gRPC 配置 ====================
# gRPC 服务监听地址
GRPC__HOST=0.0.0.0
# gRPC 服务端口
GRPC__PORT=50051

# ==================== 日志配置 ====================
# 日志级别（debug, info, warn, error）
LOG__LEVEL=info
# 日志文件目录
LOG__DIR=/var/log/面料 ERP/

# ==================== CORS 配置 ====================
# 允许的跨域来源列表（多个用逗号分隔）
CORS__ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== 其他配置 ====================
# 运行环境（development, production）
ENV=development
