2026-06-12T09:44:36.603236Z  INFO http.request{method=POST path=/api/v1/erp/init/initialize-with-db trace_id=6aa87b42453d4695aa8ca46256e39925 span_id=6b6f373271fe0acf parent_span_id="" sampled=true}: sqlx::query: summary="-- 添加乐观锁版本号到库存表 -- 用于并发控制，防止库存超卖 …" db.statement="\n\n-- 添加乐观锁版本号到库存表\n-- 用于并发控制，防止库存超卖\n\nALTER TABLE \"inventory_stocks\" ADD COLUMN \"version\" INTEGER NOT NULL DEFAULT 0;\n\nCOMMENT ON COLUMN \"inventory_stocks\".\"version\" IS '乐观锁版本号，用于并发控制';\n\n" rows_affected=0 rows_returned=0 elapsed=55.859143ms elapsed_secs=0.055859143
