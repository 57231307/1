2026-06-12T11:12:29.476765Z  INFO http.request{method=POST path=/api/v1/erp/init/initialize-with-db trace_id=62bd4f4464cd482e8222ca5b0bc71988 span_id=5d7b9de93556ab1c parent_span_id="" sampled=true}: sqlx::query: summary="CREATE INDEX \"idx_users_department_id\" ON …" db.statement="\n\nCREATE INDEX \"idx_users_department_id\" ON \"users\" (\"department_id\")\n" rows_affected=0 rows_returned=0 elapsed=124.706152ms elapsed_secs=0.124706152
