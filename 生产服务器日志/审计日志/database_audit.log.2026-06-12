2026-06-12T11:19:26.734618Z  INFO http.request{method=POST path=/api/v1/erp/init/initialize-with-db trace_id=fa668dd8ebdb4b3eab9360aee59adb5e span_id=eef5399ce5537fdc parent_span_id="" sampled=true}: sqlx::query: summary="INSERT INTO \"seaql_migrations\" (\"version\", …" db.statement="\n\nINSERT INTO \"seaql_migrations\" (\"version\", \"applied_at\") VALUES ($1, $2) RETURNING \"version\"\n" rows_affected=1 rows_returned=1 elapsed=62.930861ms elapsed_secs=0.062930861
