2026-06-12T09:44:31.436502Z  INFO http.request{method=POST path=/api/v1/erp/init/initialize-with-db trace_id=6aa87b42453d4695aa8ca46256e39925 span_id=6b6f373271fe0acf parent_span_id="" sampled=true}: sqlx::query: summary="-- 创建染色批次和配方表 CREATE TABLE …" db.statement="\n\n-- 创建染色批次和配方表\nCREATE TABLE IF NOT EXISTS \"dye_batch\" (\n    \"id\" SERIAL PRIMARY KEY,\n    \"batch_no\" VARCHAR(50) NOT NULL UNIQUE,\n    \"color_code\" VARCHAR(50) NOT NULL,\n    \"color_name\" VARCHAR(100) NOT NULL,\n    \"fabric_type\" VARCHAR(100),\n    \"weight_kg\" DECIMAL(10,2),\n    \"status\" VARCHAR(20) NOT NULL DEFAULT 'pending',\n    \"production_date\" TIMESTAMPTZ,\n    \"completion_date\" TIMESTAMPTZ,\n    \"quality_grade\" VARCHAR(20),\n    \"remarks\" TEXT,\n    \"created_by\" INTEGER,\n    \"created_at\" TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    \"updated_at\" TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\nCREATE TABLE IF NOT EXISTS \"dye_recipe\" (\n    \"id\" SERIAL PRIMARY KEY,\n    \"recipe_name\" VARCHAR(100) NOT NULL,\n    \"color_code\" VARCHAR(50) NOT NULL,\n    \"ingredients\" JSONB,\n    \"instructions\" TEXT,\n    \"created_by\" INTEGER,\n    \"created_at\" TIMESTAMPTZ NOT NULL DEFAULT NOW(),\n    \"updated_at\" TIMESTAMPTZ NOT NULL DEFAULT NOW()\n);\n\n" rows_affected=0 rows_returned=0 elapsed=73.719743ms elapsed_secs=0.073719743
