2026-06-12T11:12:36.042064Z  INFO http.request{method=POST path=/api/v1/erp/init/initialize-with-db trace_id=62bd4f4464cd482e8222ca5b0bc71988 span_id=5d7b9de93556ab1c parent_span_id="" sampled=true}: sqlx::query: summary="-- 添加乐观锁版本号到库存表 -- 用于并发控制，防止库存超卖 …" db.statement="\n\n-- 添加乐观锁版本号到库存表\n-- 用于并发控制，防止库存超卖\n\nALTER TABLE \"inventory_stocks\" ADD COLUMN \"version\" INTEGER NOT NULL DEFAULT 0;\n\nCOMMENT ON COLUMN \"inventory_stocks\".\"version\" IS '乐观锁版本号，用于并发控制';\n\n" rows_affected=0 rows_returned=0 elapsed=55.459464ms elapsed_secs=0.055459464
