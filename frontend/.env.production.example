# =====================================================
# 冰溪 ERP 前端 - 生产环境配置模板
# =====================================================
# 用途：生产构建时的环境变量模板
# 复制为 .env.production 后根据实际部署情况修改
# 重要：.env.production 必须加入 .gitignore 永远不提交！
# =====================================================

# ===== 运行环境 =====
NODE_ENV=production

# ===== API 基础地址 =====
# 同源部署：使用相对路径（推荐）
VITE_API_BASE_URL=/api/v1/erp
# 跨域部署示例：VITE_API_BASE_URL=https://api.example.com/api/v1/erp

# ===== API 请求超时（毫秒） =====
VITE_API_TIMEOUT=30000

# ===== 运行时模式（生产必须 false） =====
# 是否启用 mock 数据（生产永远 false，避免泄露测试数据）
VITE_USE_MOCK=false
# mock 数据模拟延迟（生产为 0）
VITE_MOCK_DELAY=0

# ===== 调试与错误显示（生产必须 false） =====
# 是否启用调试模式（生产永远 false）
VITE_DEBUG=false
# 是否在 UI 上显示详细错误堆栈（生产永远 false）
VITE_SHOW_ERROR_DETAILS=false

# ===== 应用元信息（可选） =====
VITE_APP_TITLE=冰溪 ERP
VITE_APP_VERSION=__BUILD_VERSION__

# ===== CDN 资源地址（可选） =====
# 静态资源 CDN 前缀（留空则使用相对路径）
# VITE_CDN_BASE_URL=https://cdn.example.com

# ===== 第三方服务密钥（如有） =====
# ⚠️ 注意：仅前端可公开的 key 才能放在这里，敏感 secret 必须在后端
# 例如：百度统计、谷歌分析、sentry 公开 dsn 等
# VITE_BAIDU_ANALYTICS_ID=
# VITE_SENTRY_DSN=
# VITE_GA_ID=
