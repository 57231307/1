# 色卡仓储管理配置示例
# 复制此文件为 color-card.toml 并根据实际环境修改

[color_card]
# 多租户默认配置
default_tenant_id = 1

# 色号批量导入配置
[color_card.import]
# 单次导入最大色号数
max_items_per_batch = 1000
# 单次导入最大文件大小（MB）
max_file_size_mb = 10
# 是否自动计算 CMYK 和 Lab
auto_compute_color_space = true

# 借出管理配置
[color_card.borrow]
# 默认借出天数上限
max_borrow_days = 30
# 遗失赔付是否需要审批
lost_compensation_requires_approval = true
# 损坏赔付阈值（超过此金额需要审批）
damaged_compensation_approval_threshold = 1000.0

# 扫码查询配置
[color_card.scan]
# 是否缓存扫码结果（秒）
cache_ttl_seconds = 300
# 是否返回配方详情
include_recipe = true
# 是否返回价格详情
include_price = true

# 行业规则
[color_card.industry]
# ΔE 色差可接受阈值
delta_e_threshold = 3.0
# 是否启用 PANTONE 编码校验
validate_pantone = false
# 是否启用 CNCS 编码校验
validate_cncs = false
