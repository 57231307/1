# P0-5 面料多色号定价扩展 - 环境变量
# 复制为 .env 后生效

# PostgreSQL
POSTGRES_DB=bingxi
POSTGRES_USER=bingxi
POSTGRES_PASSWORD=bingxi_p0_5_test
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# 后端
DATABASE_URL=postgres://bingxi:bingxi_p0_5_test@postgres:5432/bingxi
RUST_LOG=info
BIND_ADDR=0.0.0.0:8081

# JWT
JWT_SECRET=bingxi-p0-5-test-secret

# 多租户
TENANT_MODE=multi

# P0-5 价格配置
PRICE_APPROVAL_THRESHOLD=0.10   # 调价审批阈值（10%）
PRICE_VIP_DISCOUNT=0.95          # VIP 客户折扣（95 折）
PRICE_GOLD_DISCOUNT=0.90         # GOLD 客户折扣（9 折）

# 前端
FRONTEND_PORT=8080
