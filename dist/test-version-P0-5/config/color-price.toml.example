# 面料多色号定价扩展模块配置示例
# 复制为 color-price.toml 后生效

# 调价审批阈值（涨跌幅超过此值需审批）
approval_threshold = 0.10

# 客户等级折扣
[customer_level_discount]
VIP = 0.95     # 95 折
GOLD = 0.90    # 9 折
SILVER = 0.95  # 95 折
NORMAL = 1.00  # 不打折

# 季节定义
[season]
SS = { start_month = 3, end_month = 8, label = "春夏" }
AW = { start_month = 9, end_month = 2, label = "秋冬" }
HOLIDAY = { label = "节日" }

# 阶梯价默认值（数量 + 折扣）
[default_tier]
"1-99" = 1.00
"100-499" = 0.95
"500-999" = 0.90
"1000+" = 0.85

# 价格预警阈值
[alert]
warn_increase = 0.20    # 涨幅 > 20% 预警
warn_decrease = -0.30   # 跌幅 > 30% 预警
expire_warn_days = 7    # 价格过期前 7 天预警
