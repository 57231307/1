# 冰溪 ERP 环境变量示例
# 复制为 .env 并填入实际值

# ============ PostgreSQL 主库 ============
POSTGRES_USER=bingxi
POSTGRES_DB=bingxi
POSTGRES_PRIMARY_PASSWORD=please_change_to_secure_password
POSTGRES_BACKUP_PASSWORD=please_change_to_secure_password

# ============ 主备复制 ============
REPLICATION_USER=replicator
REPLICATION_PASSWORD=please_change_to_secure_password

# ============ 数据库连接 ============
DATABASE_URL_PRIMARY=postgresql://bingxi:please_change_to_secure_password@postgres-primary:5432/bingxi
DATABASE_URL_BACKUP=postgresql://bingxi:please_change_to_secure_password@postgres-backup:5432/bingxi

# ============ JWT 密钥 ============
JWT_SECRET=please_generate_with_openssl_rand_hex_32
COOKIE_SECRET=bingxi-cookie-secret-please-change

# ============ Redis ============
# 默认值：redis://redis-primary:6379
# REDIS_URL=redis://redis-primary:6379
